							"I know!{PAUSE 20}\nyou're a trainer, right?\lMaybe we could do a trade!\pI'd take any BUG TYPE over this {STR_VAR_2}…"), MSGBOX_DEFAULT)
			setvar(VAR_0x8005, INGAME_TRADE_BUG_CATCHER)
			setvar(VAR_0x8003, TYPE_BUG)
