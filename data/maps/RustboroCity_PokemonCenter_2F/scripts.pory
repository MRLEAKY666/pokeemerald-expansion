raw `
RustboroCity_PokemonCenter_2F_MapScripts::
	map_script MAP_SCRIPT_ON_FRAME_TABLE, CableClub_OnFrame
	map_script MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE, CableClub_OnWarp
	map_script MAP_SCRIPT_ON_LOAD, CableClub_OnLoad
	map_script MAP_SCRIPT_ON_TRANSITION, RustboroCity_PokemonCenter_2F_OnTransition
	.byte 0

`

script RustboroCity_PokemonCenter_2F_OnTransition{
	call(RustboroCity_PokemonCenter_2F_EventScript_SetSpRoamingNPC)
	call(RustboroCity_PokemonCenter_2F_EventScript_SetTrRoamingNPC)
	call(RustboroCity_PokemonCenter_2F_EventScript_SetPkmnTrRoamingNPC)
	end
}

script RustboroCity_PokemonCenter_2F_EventScript_SetSpRoamingNPC{
	checkroamingnpcatlocation(FLAG_ROAMING_WALLACE, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_OBJ_GFX_ID_A, OBJ_EVENT_GFX_WALLACE)
	}
	else{
		setflag(FLAG_TEMP_A)
	}
	return
}

script RustboroCity_PokemonCenter_2F_EventScript_SpRoamingNPC{
	if (var(VAR_OBJ_GFX_ID_A) == OBJ_EVENT_GFX_WALLACE){
		goto(RustboroCity_PokemonCenter_2F_EventScript_Wallace)
	}
}

script RustboroCity_PokemonCenter_2F_EventScript_SetTrRoamingNPC{
	if (checkroamingnpcatlocation(FLAG_ROAMING_SCIENTIST, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_B, OBJ_EVENT_GFX_SCIENTIST_1)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_BREEDER, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_B, OBJ_EVENT_GFX_MAN_4)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_HIKER, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_B, OBJ_EVENT_GFX_HIKER)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_RANGER, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_B, OBJ_EVENT_GFX_CAMPER)
	}
	else{
		setflag(FLAG_TEMP_B)
	}
	return
}

script RustboroCity_PokemonCenter_2F_EventScript_SetPkmnTrRoamingNPC{
	if (flag(FLAG_POST_WHITEOUT)){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_SCIENTIST_2)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_PSYCHIC, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_LASS)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_BUG_CATCHER, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_BUG_CATCHER)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_YOUNGSTER, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_YOUNGSTER)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_HEX_MANIAC, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_HEX_MANIAC)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_TRIATHLETE_F, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_RUNNING_TRIATHLETE_F)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_TRIATHLETE_M, MAP_RUSTBORO_CITY_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_RUNNING_TRIATHLETE_M)
	}
	else{
		setflag(FLAG_TEMP_C)
	}
	return
}

script RustboroCity_PokemonCenter_2F_EventScript_TrRoamingNPC{
	faceplayer
	switch (var(VAR_OBJ_GFX_ID_B)){
		case OBJ_EVENT_GFX_SCIENTIST_1:
			call(RoamingTraders_EventScript_TMTrader)
		case OBJ_EVENT_GFX_MAN_4:
			call(RoamingTraders_EventScript_BallTrader)
		case OBJ_EVENT_GFX_HIKER:
			call(RoamingTraders_EventScript_SurvivalItemTrader)
		case OBJ_EVENT_GFX_CAMPER:
			call(RoamingTraders_EventScript_HerbTrader)
	}
	applymovement(VAR_LAST_TALKED, Common_Movement_WalkInPlaceLeft)
	waitmovement
	release
}

script RustboroCity_PokemonCenter_2F_EventScript_PkmnTrRoamingNPC{
	faceplayer
	call(RoamingTraders_EventScript_RoamingMonTrader)
	release
}

script RustboroCity_PokemonCenter_2F_EventScript_Wallace{
	applymovement(VAR_LAST_TALKED, Common_Movement_FacePlayer)
	waitmovement
	if (flag(FLAG_MET_WALLACE)){
		msgbox(format("WALLACE: Good to see you again, {PLAYER}."), MSGBOX_DEFAULT)
		call(SootopolisCity_House3_EventScript_WallaceCheckBeasts)
	}
	else{
		msgbox(format("Ah, a young TRAINER…\p"
						"Yes, I can tell you're one to watch.\p"
						"But how rude of me,\Nmy name is WALLACE, former GYM LEADER of SOOTOPOLIS CITY.\p"
						"As many trainer's final obstacle before challenging the POKéMON LEAGUE,\NI've honed an eye for spotting promising TRAINERS.\p"
						"I can tell you'll make it there one day too."), MSGBOX_DEFAULT)
		setflag(FLAG_MET_WALLACE)
	}
	closemessage
	delay(15)
	//applymovement(VAR_LAST_TALKED, Common_Movement_WalkInPlaceLeft)
	//waitmovement
	release
	end
}

