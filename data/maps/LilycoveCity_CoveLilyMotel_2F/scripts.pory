script LilycoveCity_CoveLilyMotel_2F_EventScript_CaughtAllBirds{
	msgbox(format("Oh, that's interesting…\p"
					"You've caught the POKéMON ARTICUNO, ZAPDOS, and MOLTRES!\p"
					"To be honest, those POKéMON are exactly why I'm visiting HOENN.\p"
					"These are the three LEGENDARY BIRD POKéMON representing ICE, ELECTRIC, and FIRE!\p"
					"Thanks to this POKéDEX data, we'll be able to learn a lot about these rare and powerful POKéMON."), MSGBOX_DEFAULT)
	message(LilycoveCity_CoveLilyMotel_2F_Text_Thinking)
	waitmessage
	delay(45)
	msgbox(format("Actually…\lMaybe you can help…\p"
					"There's another LEGENDARY POKéMON related to these three.\p"
					"Yes, the POKéMON LUGIA is said to be connected to the LEGENDARY BIRD POKéMON!\p"
					"Apparently LUGIA has been known to roost in the nearby landmark NAVEL ROCK…\p"
					"But this POKéMON is a force of nature!\pMy POKéMON and I are long in the tooth; our battling days are over,\p"
					"But catching those three LEGENDARY BIRD POKéMON was quite a feat…\pYes,\nI'm sure you can help!"), MSGBOX_DEFAULT)
	if (flag(FLAG_RECEIVED_SS_TICKET)){
		msgbox(format("Take this;\nuse it to travel to NAVEL ROCK on the S.S. TIDAL."), MSGBOX_DEFAULT)
		if (!flag(FLAG_RECEIVED_MYSTIC_TICKET)) {
			giveitem(ITEM_MYSTIC_TICKET)
			setflag(FLAG_ENABLE_SHIP_NAVEL_ROCK)
			setflag(FLAG_RECEIVED_MYSTIC_TICKET)
			setflag(FLAG_START_LUGIA_QUEST)
		}
		else{
			msgbox(format("Huh?\pYou already have the MYSTIC TICKET.\p"
					"You should be all set to travel to NAVEL ROCK then."), MSGBOX_DEFAULT)
		}
	}
	else{
		msgbox(format("Take this;\pwhen the long-awaited S.S. TIDAL finally sets sail, use it to travel to NAVEL ROCK."), MSGBOX_DEFAULT)
		if (!flag(FLAG_RECEIVED_MYSTIC_TICKET)) {
			giveitem(ITEM_MYSTIC_TICKET)
			setflag(FLAG_ENABLE_SHIP_NAVEL_ROCK)
			setflag(FLAG_RECEIVED_MYSTIC_TICKET)
			setflag(FLAG_START_LUGIA_QUEST)
		}
		else{
			msgbox(format("Huh?\pYou already have the MYSTIC TICKET.\p"
					"You should be all set to travel to NAVEL ROCK then."), MSGBOX_DEFAULT)
		}
	}
	msgbox(format("I'll meet you there to discuss our next steps.\p"
						"Bring ARTICUNO, ZAPDOS, and MOLTRES with you, and be ready to catch a mighty POKéMON.\p"
						"LUGIA's POKéDEX data would be sure to make waves in the POKéMON PROFESSOR community!"), MSGBOX_DEFAULT)
	closemessage
	release
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_OakCheckPokedexEnd{
	message("Here's some advice:")
	waitmessage
	delay(40)
	special(ShowPokedexRatingMessage)
	waitmessage
	delay(45)
	msgbox(format("Trust me, I know what I'm talking about. Take it from an old-timer like me!\p"
					"To be honest, I'm here in HOENN looking for some rare POKéMON.\p"
					"Three BIRD POKéMON representing ICE, ELECTRIC, and FIRE have been spotted and are believed to be roosting here.\p"
					"Come show me your POKéDEX if you learn anything about these POKéMON!"), MSGBOX_DEFAULT)
	release
}