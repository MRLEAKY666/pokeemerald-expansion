`

script LilycoveCity_CoveLilyMotel_2F_EventScript_MeetAtNavelRock{
	msgbox(format("I'll meet you at NAVEL ROCK to discuss our next steps towards finding LUGIA.\p"
						"Bring ARTICUNO, ZAPDOS, and MOLTRES with you,\p"
						"and be ready to catch a mighty POKéMON.\p"
						"LUGIA's POKéDEX data would be sure to send a tsunami through the POKéMON PROFESSOR community!"), MSGBOX_DEFAULT)
	release
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_OakCheckPokedex{
	applymovement(LOCALID_COVELILY_OAK, Common_Movement_WalkInPlaceUp)
	delay(30)
	playse(SE_PC_ON)
	waitse
	message(LilycoveCity_CoveLilyMotel_2F_Text_Thinking)
	waitmessage
	delay(45)
	//closemessage
	setvar(VAR_0x8004, 0)
	specialvar(VAR_RESULT, ScriptGetPokedexInfo)
	copyvar(VAR_0x8008, VAR_0x8005)
	copyvar(VAR_0x8009, VAR_0x8006)
	copyvar(VAR_0x800A, VAR_RESULT)
	buffernumberstring(STR_VAR_1, VAR_0x8008  @ Num Hoenn seen)
	buffernumberstring(STR_VAR_2, VAR_0x8009  @ Num Hoenn caught)
	msgbox("Ah, so you've seen {STR_VAR_1} of HOENN's\nnative POKéMON.\pYou've even caught {STR_VAR_2} of them!", MSGBOX_DEFAULT)
	if (flag(FLAG_SYS_NATIONAL_DEX)){
		setvar(VAR_0x8004, 1)
	specialvar(VAR_RESULT, ScriptGetPokedexInfo)
	copyvar(VAR_0x8008, VAR_0x8005)
	copyvar(VAR_0x8009, VAR_0x8006)
	buffernumberstring(STR_VAR_1, VAR_0x8008)  // Num National seen
	buffernumberstring(STR_VAR_2, VAR_0x8009)  // Num National caught
	msgbox("And on a nationwide basis…\pYou've seen {STR_VAR_1} POKéMON,\nand you've caught {STR_VAR_2} POKéMON…$", MSGBOX_DEFAULT)
	}

	setvar(VAR_TEMP_4, 0)
	getseenmon(SPECIES_ARTICUNO)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_TEMP_0, 1)
		addvar(VAR_TEMP_4, 1)
	}
	getseenmon(SPECIES_ZAPDOS)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_TEMP_1, 2)
		addvar(VAR_TEMP_4, 2)
	}
	getseenmon(SPECIES_MOLTRES)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_TEMP_2, 4)
		addvar(VAR_TEMP_4, 4)
	}
	message(LilycoveCity_CoveLilyMotel_2F_Text_Thinking)
	waitmessage
	delay(45)
	switch (var(VAR_TEMP_4)){
		case 0: // seen no legendary birds
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_OakCheckPokedexEnd)
		case 1: // seen only articuno
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SeenArticuno)
		case 2: // seen only zapdos
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SeenZapdos)
		case 4: // seen only moltres
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SeenMoltres)
		case 3: // seen articuno and zapdos
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SeenArticunoAndZapdos)
		case 5: // seen articuno and moltres
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SeenArticunoAndMoltres)
		case 6: // seen zapdos and moltres
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SeenZapdosAndMoltres)
		case 7: // seen all three
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SeenAllBirds)
		default:
			special(DoSoftReset)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_OakCheckPokedexEnd)
	}
	release
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_SeenArticuno{
	getcaughtmon(SPECIES_ARTICUNO)
	if (var(VAR_RESULT) == TRUE) {
		msgbox(format("Oh, that's interesting…\p"
						"You've even caught the POKéMON ARTICUNO!\p"
						"To be honest, that POKéMON is exactly why I'm visiting HOENN!\p"
						"Three BIRD POKéMON representing ICE, ELECTRIC, and FIRE have been spotted and are believed to be roosting here.\p"
						"ARTICUNO is one of these POKéMON!\p"
						"Thanks to this POKéDEX data, we'll be able to learn a lot about this rare and powerful POKéMON.\p"
						"Come show me your POKéDEX again if you learn anything about the other two POKéMON!"), MSGBOX_DEFAULT)
	}
	else{
		msgbox(format("Oh, that's interesting…\p"
						"You've seen the POKéMON ARTICUNO!\p"
						"To be honest, that POKéMON is exactly why I'm visiting HOENN!\p"
						"Three BIRD POKéMON representing ICE, ELECTRIC, and FIRE have been spotted and are believed to be roosting here.\p"
						"ARTICUNO is one of these POKéMON!\p"
						"If you manage to catch that POKéMON, please show me your POKéDEX again!"), MSGBOX_DEFAULT)
	}	
	closemessage
	release
}

