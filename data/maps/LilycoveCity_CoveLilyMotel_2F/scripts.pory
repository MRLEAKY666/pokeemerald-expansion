script LilycoveCity_CoveLilyMotel_2F_EventScript_SeenArticunoAndZapdos{
	setvar(VAR_TEMP_4, 0)
	getcaughtmon(SPECIES_ARTICUNO)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_TEMP_1, 1)
		addvar(VAR_TEMP_4, 1)
	}
	getcaughtmon(SPECIES_ZAPDOS)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_TEMP_2, 2)
		addvar(VAR_TEMP_4, 2)
	}
	switch (var(VAR_TEMP_4)){
		case 0: // caught no legendary birds
			bufferspeciesname(STR_VAR_1, SPECIES_ARTICUNO)
			bufferspeciesname(STR_VAR_2, SPECIES_ZAPDOS)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtNoneBird)
		case 1: // caught only articuno
			bufferspeciesname(STR_VAR_1, SPECIES_ARTICUNO)
			bufferspeciesname(STR_VAR_2, SPECIES_ZAPDOS)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtOneBird)
		case 2: // caught only zapdos
			bufferspeciesname(STR_VAR_1, SPECIES_ZAPDOS)
			bufferspeciesname(STR_VAR_2, SPECIES_ARTICUNO)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtOneBird)
		case 3: // caught articuno and zapdos
			bufferspeciesname(STR_VAR_1, SPECIES_ARTICUNO)
			bufferspeciesname(STR_VAR_2, SPECIES_ZAPDOS)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtTwoBirds)
		default:
			special(DoSoftReset)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_OakCheckPokedexEnd)
	}
	release
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_SeenArticunoAndMoltres{
	setvar(VAR_TEMP_4, 0)
	getcaughtmon(SPECIES_ARTICUNO)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_TEMP_1, 1)
		addvar(VAR_TEMP_4, 1)
	}
	getcaughtmon(SPECIES_MOLTRES)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_TEMP_2, 4)
		addvar(VAR_TEMP_4, 4)
	}
	switch (var(VAR_TEMP_4)){
		case 0: // caught no legendary birds
			bufferspeciesname(STR_VAR_1, SPECIES_ARTICUNO)
			bufferspeciesname(STR_VAR_2, SPECIES_MOLTRES)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtNoneBird)
		case 1: // caught only articuno
			bufferspeciesname(STR_VAR_1, SPECIES_ARTICUNO)
			bufferspeciesname(STR_VAR_2, SPECIES_MOLTRES)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtOneBird)
		case 4: // caught only moltres
			bufferspeciesname(STR_VAR_1, SPECIES_MOLTRES)
			bufferspeciesname(STR_VAR_2, SPECIES_ARTICUNO)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtOneBird)
		case 5: // caught articuno and moltres
			bufferspeciesname(STR_VAR_1, SPECIES_ARTICUNO)
			bufferspeciesname(STR_VAR_2, SPECIES_MOLTRES)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtTwoBirds)
		default:
			special(DoSoftReset)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_OakCheckPokedexEnd)
	}
	release
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_SeenZapdosAndMoltres{
	setvar(VAR_TEMP_4, 0)
	getcaughtmon(SPECIES_ZAPDOS)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_TEMP_1, 2)
		addvar(VAR_TEMP_4, 2)
	}
	getcaughtmon(SPECIES_MOLTRES)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_TEMP_2, 4)
		addvar(VAR_TEMP_4, 4)
	}
	switch (var(VAR_TEMP_4)){
		case 0: // caught no legendary birds
			bufferspeciesname(STR_VAR_1, SPECIES_ZAPDOS)
			bufferspeciesname(STR_VAR_2, SPECIES_MOLTRES)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtNoneBird)
		case 2: // caught only zapdos
			bufferspeciesname(STR_VAR_1, SPECIES_ZAPDOS)
			bufferspeciesname(STR_VAR_2, SPECIES_MOLTRES)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtOneBird)
		case 4: // caught only moltres
			bufferspeciesname(STR_VAR_1, SPECIES_MOLTRES)
			bufferspeciesname(STR_VAR_2, SPECIES_ZAPDOS)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtOneBird)
		case 6: // caught zapdos and moltres
			bufferspeciesname(STR_VAR_1, SPECIES_ZAPDOS)
			bufferspeciesname(STR_VAR_2, SPECIES_MOLTRES)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_SawTwoCaughtTwoBirds)
		default:
			special(DoSoftReset)
			goto(LilycoveCity_CoveLilyMotel_2F_EventScript_OakCheckPokedexEnd)
	}
	release
}

