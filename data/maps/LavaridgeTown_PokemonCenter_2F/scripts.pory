raw `
LavaridgeTown_PokemonCenter_2F_MapScripts::
	map_script MAP_SCRIPT_ON_FRAME_TABLE, CableClub_OnFrame
	map_script MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE, CableClub_OnWarp
	map_script MAP_SCRIPT_ON_LOAD, CableClub_OnLoad
	map_script MAP_SCRIPT_ON_TRANSITION, LavaridgeTown_PokemonCenter_2F_OnTransition
	.byte 0

`

script LavaridgeTown_PokemonCenter_2F_OnTransition{
	if (var(VAR_LAVARBOR_TUNNEL_QUEST_STATE) == 0){
		setflag(FLAG_LAVARIDGE_BREAK_NURSE)
	}
	call(LavaridgeTown_PokemonCenter_2F_EventScript_SetSpRoamingNPC)
	call(LavaridgeTown_PokemonCenter_2F_EventScript_SetTrRoamingNPC)
	call(LavaridgeTown_PokemonCenter_2F_EventScript_SetPkmnTrRoamingNPC)
}

script LavaridgeTown_PokemonCenter_2F_EventScript_NurseOnBreak{
	lock
	faceplayer
	msgbox(format("Oh, hey.\pDid you want to hear about the LAVARBOR TUNNEL again?"), MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES){
		msgbox(format("Well, there were plans for a tunnel from here to FALLARBOR TOWN,\lbut the project was cancelled…\p"
						"They never made much progress…\pApparently the project leader spent too much time at the sauna instead of directing the dig.\p"
						"He's still there almost all the time!\nAfter they cancelled the project,\lhe retired here to LAVARIDGE."), MSGBOX_DEFAULT)
	}
	else{
		msgbox(format("Yeah, you're right, it's pretty boring…"), MSGBOX_DEFAULT)
	}
	closemessage
	delay(15)
	applymovement(LOCALID_LAVARIDGE_PKMNCNTR_NURSE_ON_BREAK, Common_Movement_FaceOriginalDirection)
	waitmovement(LOCALID_LAVARIDGE_PKMNCNTR_NURSE_ON_BREAK)
	release
	end
}

script LavaridgeTown_PokemonCenter_2F_EventScript_SetSpRoamingNPC{
	checkroamingnpcatlocation(FLAG_ROAMING_WALLACE, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F)
	if (var(VAR_RESULT) == TRUE){
		setvar(VAR_OBJ_GFX_ID_A, OBJ_EVENT_GFX_WALLACE)
	}
	else{
		setflag(FLAG_TEMP_A)
	}
	return
}

script LavaridgeTown_PokemonCenter_2F_EventScript_SpRoamingNPC{
	if (var(VAR_OBJ_GFX_ID_A) == OBJ_EVENT_GFX_WALLACE){
		goto(FortreeCity_PokemonCenter_2F_EventScript_Wallace)
	}
}

script LavaridgeTown_PokemonCenter_2F_EventScript_SetTrRoamingNPC{
	if (checkroamingnpcatlocation(FLAG_ROAMING_SCIENTIST, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_B, OBJ_EVENT_GFX_SCIENTIST_1)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_BREEDER, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_B, OBJ_EVENT_GFX_MAN_4)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_HIKER, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_B, OBJ_EVENT_GFX_HIKER)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_RANGER, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_B, OBJ_EVENT_GFX_CAMPER)
	}
	else{
		setflag(FLAG_TEMP_B)
	}
	return
}

script LavaridgeTown_PokemonCenter_2F_EventScript_SetPkmnTrRoamingNPC{
	if (flag(FLAG_POST_WHITEOUT)){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_SCIENTIST_2)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_PSYCHIC, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_LASS)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_BUG_CATCHER, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_BUG_CATCHER)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_YOUNGSTER, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_YOUNGSTER)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_HEX_MANIAC, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_HEX_MANIAC)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_TRIATHLETE_F, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_RUNNING_TRIATHLETE_F)
	}
	elif (checkroamingnpcatlocation(FLAG_ROAMING_TRIATHLETE_M, MAP_LAVARIDGE_TOWN_POKEMON_CENTER_2F) == TRUE){
		setvar(VAR_OBJ_GFX_ID_C, OBJ_EVENT_GFX_RUNNING_TRIATHLETE_M)
	}
	else{
		setflag(FLAG_TEMP_C)
	}
	return
}

script LavaridgeTown_PokemonCenter_2F_EventScript_TrRoamingNPC{
	faceplayer
	switch (var(VAR_OBJ_GFX_ID_B)){
		case OBJ_EVENT_GFX_SCIENTIST_1:
			call(RoamingTraders_EventScript_TMTrader)
		case OBJ_EVENT_GFX_MAN_4:
			call(RoamingTraders_EventScript_BallTrader)
		case OBJ_EVENT_GFX_HIKER:
			call(RoamingTraders_EventScript_SurvivalItemTrader)
		case OBJ_EVENT_GFX_CAMPER:
			call(RoamingTraders_EventScript_HerbTrader)
	}
	//applymovement(VAR_LAST_TALKED, Common_Movement_WalkInPlaceLeft)
	//waitmovement
	release
}

script LavaridgeTown_PokemonCenter_2F_EventScript_PkmnTrRoamingNPC{
	faceplayer
	call(RoamingTraders_EventScript_RoamingMonTrader)
	release
}

script LavaridgeTown_PokemonCenter_2F_EventScript_Wallace{
	applymovement(VAR_LAST_TALKED, Common_Movement_FacePlayer)
	waitmovement
	if (flag(FLAG_MET_WALLACE)){
		msgbox(format("WALLACE: Good to see you again, {PLAYER}."), MSGBOX_DEFAULT)
		call(SootopolisCity_House3_EventScript_WallaceCheckBeasts)
	}
	else{
		msgbox(format("Ah, a young TRAINER…\p"
						"Yes, I can tell you're one to watch.\p"
						"But how rude of me,\Nmy name is WALLACE, former GYM LEADER of SOOTOPOLIS CITY.\p"
						"As many trainer's final obstacle before challenging the POKéMON LEAGUE,\NI've honed an eye for spotting promising TRAINERS.\p"
						"I can tell you'll make it there one day too."), MSGBOX_DEFAULT)
		setflag(FLAG_MET_WALLACE)
	}
	closemessage
	delay(15)
	applymovement(VAR_LAST_TALKED, Common_Movement_WalkInPlaceRight)
	waitmovement
	release
	end
}

raw`

@ The below 3 are unused and leftover from RS
LavaridgeTown_PokemonCenter_2F_EventScript_Colosseum::
	call CableClub_EventScript_Colosseum
	end

LavaridgeTown_PokemonCenter_2F_EventScript_TradeCenter::
	call CableClub_EventScript_TradeCenter
	end

LavaridgeTown_PokemonCenter_2F_EventScript_RecordCorner::
	call CableClub_EventScript_RecordCorner
	end

`
